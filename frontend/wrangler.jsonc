{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "formula1-picks",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "directory": "dist",
  },
  "compatibility_flags": ["nodejs_compat"],
  "env": {
    "staging": {
      "name": "formula1-picks-staging",
    },
    "production": {
      "name": "formula1-picks",
    },
  },
}
